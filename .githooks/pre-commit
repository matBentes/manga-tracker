#!/bin/sh
# Auto-format and lint staged files before commit

# ── Frontend: Design-token linter (colors) ────────────────────────────────────
SCSS_STAGED=$(git diff --cached --name-only --diff-filter=ACM \
  | grep '^frontend/src/.*\.scss$' \
  | grep -v '_tokens\.scss$')

if [ -n "$SCSS_STAGED" ]; then
  # Convert repo-relative paths to absolute paths for the linter
  SCSS_ABS=$(echo "$SCSS_STAGED" | while read -r f; do echo "$PWD/$f"; done)
  if ! echo "$SCSS_ABS" | xargs node frontend/tools/lint-design-tokens.js; then
    echo ""
    echo "Commit blocked: use design tokens instead of hardcoded colors."
    echo "Token file: frontend/src/styles/_tokens.scss"
    exit 1
  fi
fi

# ── Frontend: Prettier ────────────────────────────────────────────────────────
FRONTEND_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '^frontend/src/.*\.\(ts\|html\|scss\|json\)$')

if [ -n "$FRONTEND_STAGED" ]; then
  cd frontend
  echo "$FRONTEND_STAGED" | sed 's|^frontend/||' | xargs npx prettier --write
  echo "$FRONTEND_STAGED" | xargs git add
  cd ..
fi

# ── Backend: Spotless (skips gracefully if JVM not available) ─────────────────
BACKEND_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '^backend/.*\.java$')

if [ -n "$BACKEND_STAGED" ] && command -v java >/dev/null 2>&1; then
  cd backend
  ./gradlew spotlessApply --no-daemon -q
  echo "$BACKEND_STAGED" | xargs git add
  cd ..
fi
