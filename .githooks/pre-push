#!/bin/sh
# Block direct pushes to main by default.
# Override intentionally with: ALLOW_MAIN_PUSH=1 git push origin main

if [ "${ALLOW_MAIN_PUSH:-0}" = "1" ]; then
  exit 0
fi

blocked=0

while read -r local_ref local_sha remote_ref remote_sha
do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    blocked=1
    break
  fi
done

if [ "$blocked" -eq 1 ]; then
  echo ""
  echo "Push blocked: direct pushes to 'main' are disabled in this repository."
  echo "Use feature branch + pull request, then merge after CI is green."
  echo ""
  echo "If this push is intentional, run:"
  echo "  ALLOW_MAIN_PUSH=1 git push origin main"
  echo ""
  exit 1
fi

exit 0
