# Web Push (VAPID) keys. Copy to .env and fill in real values.
# In AWS production, inject these from Secrets Manager via the ECS task definition.
# Generate a pair with: npx web-push generate-vapid-keys --json
# The PRIVATE key is a secret — never commit it (.env is gitignored).

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Auth JWT signing secret. Use a long random value (at least 32 bytes).
# In AWS production, inject this from Secrets Manager as JWT_SECRET.
JWT_SECRET=

# Seed account passwords (backend UserSeeder). If unset, that account is skipped and
# its login/dashboard won't work. DEMO is the public recruiter login; OWNER is private.
# In AWS production, inject these from Secrets Manager if account seeding is needed.
OWNER_PASSWORD=
DEMO_PASSWORD=

# Production database settings are not needed for local docker compose because compose sets them.
# In AWS production, inject DB_URL, DB_USERNAME, and DB_PASSWORD from Secrets Manager.
# DB_URL example: jdbc:postgresql://<rds-endpoint>:5432/manga_tracker
